# AIverse — Supabase Configuration Template
# Copy this file to .env.local and fill in your values
# Found at: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Pré-lancement : avant cette date/heure (ISO 8601), seule la page « bientôt » s’affiche.
# Défaut dans le code : 2026-03-30T00:00:00+01:00 (ouverture après le 29 mars)
# VITE_LAUNCH_AT=2026-03-30T00:00:00+01:00

# En développement : afficher le site complet malgré la date (true / false)
# VITE_BYPASS_PRELAUNCH=true
